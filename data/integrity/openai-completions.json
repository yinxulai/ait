{
  "version": "ait.integrity.rules/v1",
  "suite": "openai-completions-smoke",
  "description": "OpenAI Chat Completions API 基础能力验证规则：覆盖 AIT 当前 integrity 执行器可观测的非流式响应、流式响应、输出结构、finish_reason、usage 和基础 latency 指标。来源：https://developers.openai.com/api/reference/resources/chat/subresources/completions/methods/create/index.md",
  "cases": [
    {
      "id": "chat-completions-basic-non-stream",
      "name": "Chat Completions 非流式基础响应",
      "description": "发送最小文本对话，验证非流式响应返回 chat.completion 对象、assistant 消息、finish_reason 和 usage。",
      "category": "protocol",
      "capability": "basic_request",
      "required": true,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Reply with exactly one short greeting."
            }
          ]
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.body.exists",
          "level": "error",
          "path": "response.body",
          "op": "exists",
          "message": "响应体必须是可解析的 JSON 对象。"
        },
        {
          "id": "response.id.exists",
          "level": "error",
          "path": "response.body.id",
          "op": "exists",
          "message": "Chat Completions 响应必须包含 id。"
        },
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "非流式响应 object 必须是 chat.completion。"
        },
        {
          "id": "response.created.exists",
          "level": "warn",
          "path": "response.body.created",
          "op": "exists",
          "message": "响应建议包含 created Unix 时间戳。"
        },
        {
          "id": "response.model.exists",
          "level": "error",
          "path": "response.body.model",
          "op": "exists",
          "message": "响应必须包含实际使用的 model。"
        },
        {
          "id": "response.choices.exists",
          "level": "error",
          "path": "response.body.choices",
          "op": "exists",
          "message": "响应必须包含 choices 数组。"
        },
        {
          "id": "response.first_choice.index.exists",
          "level": "warn",
          "path": "response.body.choices[0].index",
          "op": "exists",
          "message": "第一个 choice 建议包含 index。"
        },
        {
          "id": "response.first_choice.message.exists",
          "level": "error",
          "path": "response.body.choices[0].message",
          "op": "exists",
          "message": "第一个 choice 必须包含 message。"
        },
        {
          "id": "response.first_choice.message.role.assistant",
          "level": "error",
          "path": "response.body.choices[0].message.role",
          "op": "eq",
          "value": "assistant",
          "message": "模型回复 message.role 必须是 assistant。"
        },
        {
          "id": "response.first_choice.message.content.exists",
          "level": "error",
          "path": "response.body.choices[0].message.content",
          "op": "exists",
          "message": "基础文本回复必须包含 message.content。"
        },
        {
          "id": "response.first_choice.finish_reason.valid",
          "level": "error",
          "path": "response.body.choices[0].finish_reason",
          "op": "in",
          "value": [
            "stop",
            "length",
            "tool_calls",
            "content_filter",
            "function_call"
          ],
          "message": "finish_reason 必须是 Chat Completions 文档定义的取值之一。"
        },
        {
          "id": "response.usage.exists",
          "level": "warn",
          "path": "response.body.usage",
          "op": "exists",
          "message": "响应建议包含 usage 统计。"
        },
        {
          "id": "response.usage.prompt_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.prompt_tokens",
          "op": "gte",
          "value": 0,
          "message": "usage.prompt_tokens 应为非负数。"
        },
        {
          "id": "response.usage.completion_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.completion_tokens",
          "op": "gte",
          "value": 0,
          "message": "usage.completion_tokens 应为非负数。"
        },
        {
          "id": "response.usage.total_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.total_tokens",
          "op": "gte",
          "value": 0,
          "message": "usage.total_tokens 应为非负数。"
        },
        {
          "id": "metrics.total_ms.gte_zero",
          "level": "warn",
          "path": "metrics.total_ms",
          "op": "gte",
          "value": 0,
          "message": "请求总耗时必须可观测。"
        },
        {
          "id": "metrics.input_tokens.gte_zero",
          "level": "warn",
          "path": "metrics.input_tokens",
          "op": "gte",
          "value": 0,
          "message": "AIT 应能从 usage 中提取输入 token 数。"
        },
        {
          "id": "metrics.output_tokens.gte_zero",
          "level": "warn",
          "path": "metrics.output_tokens",
          "op": "gte",
          "value": 0,
          "message": "AIT 应能从 usage 中提取输出 token 数。"
        }
      ]
    },
    {
      "id": "chat-completions-stream-basic",
      "name": "Chat Completions 流式基础响应",
      "description": "发送 stream=true 的基础请求，验证当前客户端会附带 stream_options.include_usage，并验证 SSE 数据可以解析为 chat.completion.chunk 序列。",
      "category": "protocol",
      "capability": "streaming",
      "required": true,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Count from 1 to 3, separated by commas."
            }
          ],
          "stream": true,
          "stream_options": {
            "include_usage": true
          }
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.stream_chunks.exists",
          "level": "error",
          "path": "response.body[0]",
          "op": "exists",
          "message": "流式响应必须至少包含一个可解析的 SSE data chunk。"
        },
        {
          "id": "response.first_chunk.id.exists",
          "level": "error",
          "path": "response.body[0].id",
          "op": "exists",
          "message": "流式 chunk 必须包含 id。"
        },
        {
          "id": "response.first_chunk.object.chat_completion_chunk",
          "level": "error",
          "path": "response.body[0].object",
          "op": "eq",
          "value": "chat.completion.chunk",
          "message": "流式 chunk object 必须是 chat.completion.chunk。"
        },
        {
          "id": "response.first_chunk.choices.exists",
          "level": "error",
          "path": "response.body[0].choices",
          "op": "exists",
          "message": "流式 chunk 必须包含 choices。"
        },
        {
          "id": "response.first_chunk.delta.exists",
          "level": "error",
          "path": "response.body[0].choices[0].delta",
          "op": "exists",
          "message": "流式 chunk 必须包含 choices[0].delta。"
        },
        {
          "id": "metrics.ttft_ms.gte_zero",
          "level": "warn",
          "path": "metrics.ttft_ms",
          "op": "gte",
          "value": 0,
          "message": "流式请求应可观测 TTFT。"
        },
        {
          "id": "metrics.total_ms.gte_zero",
          "level": "warn",
          "path": "metrics.total_ms",
          "op": "gte",
          "value": 0,
          "message": "流式请求总耗时必须可观测。"
        }
      ]
    },
    {
      "id": "chat-completions-system-sampling-raw",
      "name": "Chat Completions 系统消息与采样参数",
      "description": "发送包含 system/user messages 与采样控制参数的对话，验证服务端仍返回合法 chat.completion、assistant 文本、finish_reason 与 usage。",
      "category": "protocol",
      "capability": "request_parameters",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "system",
              "content": "You are a concise JSON-aware assistant."
            },
            {
              "role": "user",
              "content": "Reply with exactly one short greeting."
            }
          ],
          "temperature": 0,
          "top_p": 1,
          "presence_penalty": 0,
          "frequency_penalty": 0,
          "max_tokens": 32,
          "seed": 42,
          "user": "ait-integrity"
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "带采样参数的非流式响应 object 必须是 chat.completion。"
        },
        {
          "id": "response.first_choice.message.content.exists",
          "level": "error",
          "path": "response.body.choices[0].message.content",
          "op": "exists",
          "message": "带采样参数的基础文本回复必须包含 message.content。"
        },
        {
          "id": "response.finish_reason.valid",
          "level": "warn",
          "path": "response.body.choices[0].finish_reason",
          "op": "in",
          "value": [
            "stop",
            "length",
            "tool_calls",
            "content_filter",
            "function_call"
          ],
          "message": "带采样参数的响应应返回合法 finish_reason。"
        },
        {
          "id": "response.usage.total_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.total_tokens",
          "op": "gte",
          "value": 0,
          "message": "带采样参数的响应应返回 usage.total_tokens。"
        }
      ]
    },
    {
      "id": "chat-completions-json-response-format",
      "name": "Chat Completions JSON 响应格式",
      "description": "请求 JSON 对象输出，验证服务端响应仍是 chat.completion，且 assistant 文本内容呈 JSON 对象形态。",
      "category": "protocol",
      "capability": "response_format",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Return a valid JSON object with keys ok and message. Do not include markdown."
            }
          ],
          "response_format": {
            "type": "json_object"
          },
          "temperature": 0,
          "max_tokens": 80
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "JSON 格式响应 object 必须是 chat.completion。"
        },
        {
          "id": "response.content.looks_like_json_object",
          "level": "error",
          "path": "response.body.choices[0].message.content",
          "op": "matches",
          "value": "^\\s*\\{[\\s\\S]*\\}\\s*$",
          "message": "启用 json_object 后，assistant 文本内容应是 JSON 对象字符串。"
        },
        {
          "id": "response.finish_reason.valid",
          "level": "warn",
          "path": "response.body.choices[0].finish_reason",
          "op": "in",
          "value": [
            "stop",
            "length",
            "content_filter"
          ],
          "message": "JSON 格式响应的 finish_reason 应为常见结束类型。"
        }
      ]
    },
    {
      "id": "chat-completions-multi-choice-logprobs",
      "name": "Chat Completions 多候选与 logprobs",
      "description": "请求多个候选与 logprobs，验证服务端响应的 choices 数组、logprobs 字段和 usage 统计形态。",
      "category": "protocol",
      "capability": "multi_choice_logprobs",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Answer with one lowercase English word."
            }
          ],
          "n": 2,
          "logprobs": true,
          "top_logprobs": 2,
          "max_tokens": 8,
          "temperature": 0.7
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.first_choice.exists",
          "level": "error",
          "path": "response.body.choices[0]",
          "op": "exists",
          "message": "n=2 响应至少应包含第一个 choice。"
        },
        {
          "id": "response.second_choice.exists",
          "level": "warn",
          "path": "response.body.choices[1]",
          "op": "exists",
          "message": "支持 n=2 的服务应返回第二个 choice。"
        },
        {
          "id": "response.first_choice.logprobs.exists",
          "level": "warn",
          "path": "response.body.choices[0].logprobs",
          "op": "exists",
          "message": "支持 logprobs 的服务应返回 choices[0].logprobs。"
        },
        {
          "id": "response.usage.completion_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.completion_tokens",
          "op": "gte",
          "value": 0,
          "message": "多候选响应应返回 completion token 统计。"
        }
      ]
    },
    {
      "id": "chat-completions-stop-sequence",
      "name": "Chat Completions 停止序列",
      "description": "请求停止序列场景，验证服务端响应的 finish_reason 合法且仍返回文本内容。",
      "category": "protocol",
      "capability": "stop_sequence",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Write: alpha STOP beta"
            }
          ],
          "stop": [
            "STOP"
          ],
          "max_tokens": 32,
          "temperature": 0
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.finish_reason.valid",
          "level": "warn",
          "path": "response.body.choices[0].finish_reason",
          "op": "in",
          "value": [
            "stop",
            "length",
            "content_filter"
          ],
          "message": "停止序列响应应返回合法 finish_reason。"
        },
        {
          "id": "response.content.exists",
          "level": "error",
          "path": "response.body.choices[0].message.content",
          "op": "exists",
          "message": "停止序列响应仍应包含文本内容。"
        }
      ]
    },
    {
      "id": "chat-completions-developer-modern-controls",
      "name": "Chat Completions developer 消息与现代控制参数",
      "description": "发送包含 developer 消息与现代控制参数的对话，验证服务端仍返回合法 chat.completion 与 assistant 消息；该用例为可选，以兼容仅支持旧参数的模型或代理。",
      "category": "protocol",
      "capability": "modern_request_parameters",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "developer",
              "content": "Answer briefly and only in plain text."
            },
            {
              "role": "user",
              "content": "Say ready in one short sentence."
            }
          ],
          "max_completion_tokens": 32,
          "metadata": {
            "suite": "ait-integrity",
            "case": "chat-modern-controls"
          },
          "store": false,
          "modalities": [
            "text"
          ],
          "prompt_cache_key": "ait-integrity-chat-modern",
          "safety_identifier": "ait-integrity-user",
          "service_tier": "default",
          "parallel_tool_calls": false
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "现代参数用例仍应返回 chat.completion。"
        },
        {
          "id": "response.first_choice.message.role.assistant",
          "level": "error",
          "path": "response.body.choices[0].message.role",
          "op": "eq",
          "value": "assistant",
          "message": "模型回复 message.role 必须是 assistant。"
        },
        {
          "id": "response.first_choice.message.content.exists",
          "level": "error",
          "path": "response.body.choices[0].message.content",
          "op": "exists",
          "message": "现代参数用例应返回 assistant 文本内容。"
        }
      ]
    },
    {
      "id": "chat-completions-tools-none",
      "name": "Chat Completions 函数工具定义但禁止调用",
      "description": "提供函数工具但禁止调用，验证服务端仍返回合法 chat.completion 和普通文本 message.content。",
      "category": "protocol",
      "capability": "tools_request_shape",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Answer in plain text: what is 2 plus 2?"
            }
          ],
          "tools": [
            {
              "type": "function",
              "function": {
                "name": "lookup_number_fact",
                "description": "Look up a short fact about a number.",
                "parameters": {
                  "type": "object",
                  "properties": {
                    "number": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "number"
                  ],
                  "additionalProperties": false
                },
                "strict": true
              }
            }
          ],
          "tool_choice": "none",
          "parallel_tool_calls": false,
          "max_completion_tokens": 32,
          "temperature": 0
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "工具定义但禁止调用时仍应返回 chat.completion。"
        },
        {
          "id": "response.first_choice.message.content.exists",
          "level": "error",
          "path": "response.body.choices[0].message.content",
          "op": "exists",
          "message": "tool_choice=none 时应返回普通文本 message.content。"
        },
        {
          "id": "response.finish_reason.valid",
          "level": "warn",
          "path": "response.body.choices[0].finish_reason",
          "op": "in",
          "value": [
            "stop",
            "length",
            "tool_calls",
            "content_filter",
            "function_call"
          ],
          "message": "工具定义但禁止调用时应返回合法 finish_reason。"
        }
      ]
    },
    {
      "id": "chat-completions-cache-usage",
      "name": "Chat Completions 缓存统计响应",
      "description": "发送稳定长前缀和 prompt_cache_key，验证服务端响应仍返回 chat.completion，并观察 usage 中的缓存 token 统计字段。",
      "category": "protocol",
      "capability": "cache_usage",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "system",
              "content": "AIT cache probe stable prefix. Repeatable context for prompt caching validation. Keep this prefix identical across runs."
            },
            {
              "role": "user",
              "content": "Reply with exactly one short greeting."
            }
          ],
          "prompt_cache_key": "ait-integrity-chat-cache",
          "max_tokens": 32,
          "temperature": 0
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "缓存用例应返回 chat.completion。"
        },
        {
          "id": "response.usage.prompt_tokens_details.cached_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.prompt_tokens_details.cached_tokens",
          "op": "gte",
          "value": 0,
          "message": "支持 prompt cache 的服务应在 usage.prompt_tokens_details.cached_tokens 暴露缓存 token 数。"
        }
      ]
    },
    {
      "id": "chat-completions-reasoning-effort",
      "name": "Chat Completions 思考 token 响应统计",
      "description": "发送 reasoning_effort 场景，验证服务端仍返回合法 chat.completion，并观察 completion token 明细中的 reasoning_tokens。",
      "category": "protocol",
      "capability": "thinking_response",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Solve 17 plus 25, then answer with only the number."
            }
          ],
          "reasoning_effort": "low",
          "max_completion_tokens": 64
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "思考用例应返回 chat.completion。"
        },
        {
          "id": "response.reasoning_tokens.gte_zero",
          "level": "warn",
          "path": "response.body.usage.completion_tokens_details.reasoning_tokens",
          "op": "gte",
          "value": 0,
          "message": "支持 reasoning 的服务应在 completion_tokens_details.reasoning_tokens 暴露思考 token 数。"
        }
      ]
    },
    {
      "id": "chat-completions-non-reasoning-text",
      "name": "Chat Completions 非思考文本返回",
      "description": "发送普通文本对话，验证服务端返回 assistant 文本内容且没有强制暴露思考内容。",
      "category": "protocol",
      "capability": "non_thinking_response",
      "required": false,
      "request": {
        "body": {
          "model": "{{model}}",
          "messages": [
            {
              "role": "user",
              "content": "Answer in one short sentence: ready."
            }
          ],
          "max_tokens": 32,
          "temperature": 0
        }
      },
      "timeout_ms": 30000,
      "assertions": [
        {
          "id": "response.object.chat_completion",
          "level": "error",
          "path": "response.body.object",
          "op": "eq",
          "value": "chat.completion",
          "message": "非思考文本用例应返回 chat.completion。"
