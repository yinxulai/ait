{
  "version": "ait.integrity.rules/v1",
  "suite": "openai-responses-smoke",
  "description": "OpenAI Responses API 协议完整性验证规则",
  "assertions": [
    {
      "id": "builtin.responses.http_status",
      "case_id": "basic-response-shape",
      "level": "error",
      "path": "response.status_code",
      "op": "between",
      "value": [200, 299],
      "message": "HTTP 状态码必须在 200-299 范围内"
    },
    {
      "id": "builtin.responses.id.format",
      "case_id": "basic-response-shape",
      "level": "error",
      "path": "response.body.id",
      "op": "matches",
      "value": "^resp_[a-zA-Z0-9]+$",
      "message": "Responses API ID 必须符合 resp_xxx 格式"
    },
    {
      "id": "builtin.responses.output.exists",
      "case_id": "basic-response-shape",
      "level": "error",
      "path": "response.body.output",
      "op": "exists",
      "message": "Responses API 必须包含 output 字段"
    },
    {
      "id": "builtin.responses.output.not_empty",
      "case_id": "basic-response-shape",
      "level": "error",
      "path": "response.body.output",
      "op": "neq",
      "value": "",
      "message": "output 字段不能为空"
    },
    {
      "id": "builtin.responses.usage.exists",
      "case_id": "basic-response-shape",
      "level": "error",
      "path": "response.body.usage",
      "op": "exists",
      "message": "必须返回 usage 信息"
    },
    {
      "id": "builtin.responses.usage.total_tokens",
      "case_id": "basic-response-shape",
      "level": "error",
      "path": "response.body.usage.total_tokens",
      "op": "gt",
      "value": 0,
      "message": "total_tokens 必须大于 0"
    }
  ]
}
